<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<SplitPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
           fx:controller="client.controller.UserController"
           dividerPositions="0.65" style="-fx-background-color:#1a1a2e;">
    <VBox spacing="8" style="-fx-background-color:#1a1a2e;-fx-padding:12;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="User Management (Admin)" style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#e94560;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="selectedUserLabel" text="None selected" style="-fx-text-fill:#888;-fx-font-size:11;"/>
            <Button text="Refresh" onAction="#handleRefreshUsers"
                    style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;"/>
        </HBox>
        <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="userIdCol"   text="ID"         prefWidth="45"/>
                <TableColumn fx:id="usernameCol" text="Username"   prefWidth="110"/>
                <TableColumn fx:id="roleCol"     text="Role"       prefWidth="100"/>
                <TableColumn fx:id="fullNameCol" text="Full Name"  prefWidth="150"/>
                <TableColumn fx:id="emailCol"    text="Email"      prefWidth="160"/>
                <TableColumn fx:id="deptCol"     text="Department" prefWidth="130"/>
                <TableColumn fx:id="activeCol"   text="Active"     prefWidth="60"/>
            </columns>
            <placeholder><Label text="No users found." style="-fx-text-fill:#666;"/></placeholder>
        </TableView>
    </VBox>
    <ScrollPane fitToWidth="true" style="-fx-background:#1a1a2e;-fx-background-color:#1a1a2e;">
        <VBox spacing="10" style="-fx-background-color:#16213e;-fx-padding:16;-fx-background-radius:8;">
            <Label text="Edit User" style="-fx-font-size:15;-fx-font-weight:bold;-fx-text-fill:#e94560;"/>
            <Label text="Full Name" style="-fx-text-fill:#aaa;"/>
            <TextField fx:id="fullNameField" style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;-fx-padding:7;"/>
            <Label text="Email" style="-fx-text-fill:#aaa;"/>
            <TextField fx:id="emailField" style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;-fx-padding:7;"/>
            <Label text="Phone" style="-fx-text-fill:#aaa;"/>
            <TextField fx:id="phoneField" style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;-fx-padding:7;"/>
            <Label text="Department" style="-fx-text-fill:#aaa;"/>
            <TextField fx:id="departmentField" style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;-fx-padding:7;"/>
            <Label text="Role" style="-fx-text-fill:#aaa;"/>
            <ComboBox fx:id="roleCombo" maxWidth="Infinity"/>
            <CheckBox fx:id="activeCheckBox" text="Account Active" style="-fx-text-fill:#aaa;" selected="true"/>
            <Button text="Update User" onAction="#handleUpdateUser" maxWidth="Infinity"
                    style="-fx-background-color:#e94560;-fx-text-fill:white;-fx-font-weight:bold;-fx-background-radius:4;-fx-padding:8;"/>
            <Label fx:id="userStatusLabel" text="" wrapText="true" style="-fx-text-fill:green;"/>
        </VBox>
    </ScrollPane>
</SplitPane>