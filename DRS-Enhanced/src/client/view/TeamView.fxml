<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="client.controller.TeamController"
      spacing="8" style="-fx-background-color:#1a1a2e;-fx-padding:12;">
    <Label text="Team Coordination (Feature 1)" style="-fx-font-size:16;-fx-font-weight:bold;-fx-text-fill:#e94560;"/>
    <Label fx:id="teamStatusLabel" text="" style="-fx-text-fill:green;" wrapText="true"/>
    <SplitPane dividerPositions="0.55" VBox.vgrow="ALWAYS">
        <VBox spacing="8" style="-fx-background-color:#1a1a2e;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Response Teams" style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="selectedTeamLabel" text="None selected" style="-fx-text-fill:#888;-fx-font-size:11;"/>
                <Button text="Refresh" onAction="#handleRefreshTeams"
                        style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;"/>
            </HBox>
            <TableView fx:id="teamTable" VBox.vgrow="ALWAYS" prefHeight="240">
                <columns>
                    <TableColumn fx:id="teamIdCol"     text="ID"         prefWidth="40"/>
                    <TableColumn fx:id="teamNameCol"   text="Team Name"  prefWidth="150"/>
                    <TableColumn fx:id="deptCol"       text="Department" prefWidth="130"/>
                    <TableColumn fx:id="leaderCol"     text="Leader"     prefWidth="110"/>
                    <TableColumn fx:id="contactCol"    text="Contact"    prefWidth="100"/>
                    <TableColumn fx:id="teamStatusCol" text="Status"     prefWidth="90"/>
                    <TableColumn fx:id="membersCol"    text="Members"    prefWidth="70"/>
                </columns>
                <placeholder><Label text="No teams found." style="-fx-text-fill:#666;"/></placeholder>
            </TableView>
            <TitledPane text="Add / Edit Team" expanded="true" style="-fx-text-fill:black;font-weight: bold;">
                <GridPane hgap="10" vgap="6" style="-fx-background-color:#16213e;-fx-padding:10;">
                    <Label text="Team Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill:#aaa;"/>
                    <TextField fx:id="teamNameField" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="180"
                               style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;"/>
                    <Label text="Department:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill:#aaa;"/>
                    <ComboBox fx:id="deptCombo" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"/>
                    <Label text="Team Leader:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill:#aaa;"/>
                    <TextField fx:id="leaderField" GridPane.columnIndex="1" GridPane.rowIndex="2"
                               style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;"/>
                    <Label text="Contact:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-text-fill:#aaa;"/>
                    <TextField fx:id="contactField" GridPane.columnIndex="1" GridPane.rowIndex="3"
                               style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;"/>
                    <Label text="Capacity:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-text-fill:#aaa;"/>
                    <TextField fx:id="capacityField" text="10" GridPane.columnIndex="1" GridPane.rowIndex="4"
                               style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;"/>
                    <Label text="Members:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-text-fill:#aaa;"/>
                    <TextField fx:id="membersField" text="0" GridPane.columnIndex="1" GridPane.rowIndex="5"
                               style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;"/>
                    <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-text-fill:#aaa;"/>
                    <ComboBox fx:id="teamStatusCombo" GridPane.columnIndex="1" GridPane.rowIndex="6" maxWidth="Infinity"/>
                    <HBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2">
                        <Button text="Add Team" onAction="#handleAddTeam" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color:#e94560;-fx-text-fill:white;-fx-background-radius:4;-fx-padding:7;"/>
                        <Button text="Update Team" onAction="#handleUpdateTeam" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;-fx-padding:7;"/>
                    </HBox>
                </GridPane>
            </TitledPane>
        </VBox>
        <VBox spacing="8" style="-fx-background-color:#1a1a2e;-fx-padding:4;">
            <Label text="Team Assignments" style="-fx-font-size:13;-fx-font-weight:bold;-fx-text-fill:white;"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Disaster ID:" style="-fx-text-fill:#aaa;"/>
                <TextField fx:id="disasterIdField" promptText="e.g. 1" prefWidth="80"
                           style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;-fx-padding:6;"/>
                <Button text="Load Assignments" onAction="#handleLoadAssignments"
                        style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;"/>
            </HBox>
            <TableView fx:id="assignmentTable" VBox.vgrow="ALWAYS" prefHeight="200">
                <columns>
                    <TableColumn fx:id="assignIdCol"      text="ID"       prefWidth="40"/>
                    <TableColumn fx:id="assignTeamCol"    text="Team"     prefWidth="130"/>
                    <TableColumn fx:id="assignDisasterCol" text="Disaster" prefWidth="130"/>
                    <TableColumn fx:id="assignStatusCol"  text="Status"   prefWidth="90"/>
                    <TableColumn fx:id="assignDateCol"    text="Assigned At" prefWidth="145"/>
                </columns>
                <placeholder><Label text="Enter Disaster ID above." style="-fx-text-fill:#666;"/></placeholder>
            </TableView>
            <TitledPane text="Assign Selected Team" expanded="true" style="-fx-text-fill:black;font-weight: bold;">
                <VBox spacing="8" style="-fx-background-color:#16213e;-fx-padding:10;">
                    <Label text="1. Click team above  2. Enter Disaster ID  3. Add notes  4. Click Assign"
                           style="-fx-text-fill:#888;-fx-font-size:11;" wrapText="true"/>
                    <TextArea fx:id="assignNotesField" promptText="Optional notes..." prefRowCount="2" wrapText="true"
                              style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:4;"/>
                    <HBox spacing="8">
                        <Button text="Assign Team" onAction="#handleAssignTeam" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color:#e94560;-fx-text-fill:white;-fx-font-weight:bold;-fx-background-radius:4;-fx-padding:8;"/>
                        <Button text="Complete Assignment" onAction="#handleCompleteAssignment" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color:#4CAF50;-fx-text-fill:white;-fx-background-radius:4;-fx-padding:8;"/>
                    </HBox>
                </VBox>
            </TitledPane>
        </VBox>
    </SplitPane>
</VBox>