<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="client.controller.LoginController"
      alignment="CENTER" spacing="18"
      style="-fx-background-color:#1a1a2e;" prefWidth="480" prefHeight="520">
    <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>
    <Label text="DRS-Enhanced" style="-fx-font-size:28;-fx-font-weight:bold;-fx-text-fill:#e94560;"/>
    <Label text="Disaster Response System" style="-fx-font-size:13;-fx-text-fill:#a8a8b3;"/>
    <VBox spacing="10" style="-fx-background-color:#16213e;-fx-background-radius:10;-fx-padding:28;">
        <Label text="Username" style="-fx-text-fill:#a8a8b3;"/>
        <TextField fx:id="usernameField" promptText="Enter username"
                   style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:5;-fx-padding:10;"/>
        <Label text="Password" style="-fx-text-fill:#a8a8b3;"/>
        <PasswordField fx:id="passwordField" promptText="Enter password"
                       style="-fx-background-color:#0f3460;-fx-text-fill:white;-fx-background-radius:5;-fx-padding:10;"/>
        <Button fx:id="loginButton" text="LOGIN" onAction="#handleLogin" maxWidth="Infinity"
                style="-fx-background-color:#e94560;-fx-text-fill:white;-fx-font-weight:bold;-fx-font-size:14;-fx-background-radius:5;-fx-padding:12;"/>
        <Label fx:id="statusLabel" text="" style="-fx-text-fill:#ff6b6b;" wrapText="true"/>
        <Hyperlink text="New user? Register here" onAction="#handleRegisterLink" style="-fx-text-fill:#a8a8b3;"/>
    </VBox>
    <VBox spacing="3" alignment="CENTER">
        <Label text="Default Accounts:" style="-fx-text-fill:#555;-fx-font-size:11;"/>
        <Label text="admin/admin123  coordinator1/coord123" style="-fx-text-fill:#444;-fx-font-size:10;"/>
        <Label text="responder1/resp123  public_user/public123" style="-fx-text-fill:#444;-fx-font-size:10;"/>
    </VBox>
</VBox>